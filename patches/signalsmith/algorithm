#ifndef SIGNALSMITH_ALGORITHM_STUB_H
#define SIGNALSMITH_ALGORITHM_STUB_H

namespace std {

template<typename T>
inline T min(const T &a, const T &b) {
    return a < b ? a : b;
}

template<typename T>
inline T max(const T &a, const T &b) {
    return a > b ? a : b;
}

template<typename T>
inline void swap(T &a, T &b) {
    T temp = a;
    a = b;
    b = temp;
}

}

#endif
