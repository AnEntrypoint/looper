#ifndef SIGNALSMITH_ITERATOR_STUB_H
#define SIGNALSMITH_ITERATOR_STUB_H

namespace std {

// std::begin - get iterator to start of container
// Specialization for pointers
template<typename T>
T* begin(T* p) {
    return p;
}

template<typename T>
const T* begin(const T* p) {
    return p;
}

// General template for containers with .begin() method
template<typename Container>
auto begin(Container &c) -> decltype(c.begin()) {
    return c.begin();
}

template<typename Container>
auto begin(const Container &c) -> decltype(c.begin()) {
    return c.begin();
}

// std::end - get iterator to end of container
// Specialization for pointers (requires size_t or explicit length, so we only support containers)
template<typename Container>
auto end(Container &c) -> decltype(c.end()) {
    return c.end();
}

template<typename Container>
auto end(const Container &c) -> decltype(c.end()) {
    return c.end();
}

}

#endif
