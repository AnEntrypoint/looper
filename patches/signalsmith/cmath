#ifndef SIGNALSMITH_CMATH_STUB_H
#define SIGNALSMITH_CMATH_STUB_H

#ifndef M_PI
#define M_PI 3.14159265358979323846
#endif

extern "C" {
    double cos(double);
    double sin(double);
    double sqrt(double);
    double exp(double);
    double atan2(double, double);
    double floor(double);
    double ceil(double);
    double round(double);
    float cosf(float);
    float sinf(float);
    float sqrtf(float);
    float expf(float);
    float atan2f(float, float);
    float floorf(float);
    float ceilf(float);
    float roundf(float);
}

namespace std {
    using ::cos;
    using ::sin;
    using ::sqrt;
    using ::exp;
    using ::atan2;
    using ::floor;
    using ::ceil;
    using ::round;
    using ::cosf;
    using ::sinf;
    using ::sqrtf;
    using ::expf;
    using ::atan2f;
    using ::floorf;
    using ::ceilf;
    using ::roundf;

    // std::polar(magnitude, angle) -> complex<T>
    template<typename T>
    inline complex<T> polar(const T &mag, const T &angle) {
        return complex<T>(mag * ::cos(angle), mag * ::sin(angle));
    }

    // Overload for double version
    template<>
    inline complex<double> polar(const double &mag, const double &angle) {
        return complex<double>(mag * ::cos(angle), mag * ::sin(angle));
    }

    // Overload for float version
    template<>
    inline complex<float> polar(const float &mag, const float &angle) {
        return complex<float>(mag * ::cosf(angle), mag * ::sinf(angle));
    }
}

#endif
