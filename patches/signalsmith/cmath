#ifndef SIGNALSMITH_CMATH_STUB_H
#define SIGNALSMITH_CMATH_STUB_H

#ifndef M_PI
#define M_PI 3.14159265358979323846
#endif

extern "C" {
    double cos(double);
    double sin(double);
    double sqrt(double);
    double exp(double);
    double atan2(double, double);
    double floor(double);
    double ceil(double);
    double round(double);
    double log(double);
    double fabs(double);
    double pow(double, double);
    float cosf(float);
    float sinf(float);
    float sqrtf(float);
    float expf(float);
    float atan2f(float, float);
    float floorf(float);
    float ceilf(float);
    float roundf(float);
    float logf(float);
    float fabsf(float);
    float powf(float, float);
}

namespace std {
    using ::cos;
    using ::sin;
    using ::sqrt;
    using ::exp;
    using ::atan2;
    using ::floor;
    using ::ceil;
    using ::round;
    using ::log;
    using ::fabs;
    using ::pow;
    using ::cosf;
    using ::sinf;
    using ::sqrtf;
    using ::expf;
    using ::atan2f;
    using ::floorf;
    using ::ceilf;
    using ::roundf;
    using ::logf;
    using ::fabsf;
    using ::powf;
    inline double abs(double d) { return fabs(d); }
    inline float abs(float f) { return fabsf(f); }
}

#endif
