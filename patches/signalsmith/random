#ifndef SIGNALSMITH_RANDOM_STUB_H
#define SIGNALSMITH_RANDOM_STUB_H

#include <cstdint>

namespace std {

class random_device {
public:
    typedef unsigned int result_type;
    random_device() {}
    unsigned int operator()() {
        static unsigned int seed = 12345;
        seed = seed * 1103515245 + 12345;
        return (seed / 65536) % 32768;
    }
};

class default_random_engine {
private:
    uint32_t state;
public:
    typedef uint32_t result_type;

    default_random_engine() : state(1) {}
    explicit default_random_engine(uint32_t seed) : state(seed) {}

    uint32_t operator()() {
        state = state * 1103515245 + 12345;
        return state;
    }

    static constexpr result_type min() { return 0; }
    static constexpr result_type max() { return 0xFFFFFFFF; }
};

template<typename Engine = default_random_engine, typename Distribution = void>
class uniform_real_distribution {
public:
    typedef double result_type;

    uniform_real_distribution(double a = 0.0, double b = 1.0)
        : m_a(a), m_b(b) {}

    template<typename Generator>
    double operator()(Generator &gen) {
        uint32_t r = gen();
        double normalized = (double)r / 4294967296.0;
        return m_a + (m_b - m_a) * normalized;
    }

private:
    double m_a, m_b;
};

}

#endif
